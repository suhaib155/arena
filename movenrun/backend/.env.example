PORT=4000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/movenrun

# Redis
REDIS_URL=redis://localhost:6379

# Oracle signing key — ECDSA private key for signing GPS attestations
ORACLE_PRIVATE_KEY=0x...

# Base chain
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Contract addresses (fill after deployment)
MOVE_TOKEN_ADDRESS=0x...
ZONE_NFT_ADDRESS=0x...
GEAR_NFT_ADDRESS=0x...
ZONE_CHALLENGE_ADDRESS=0x...
SEASON_CONTROLLER_ADDRESS=0x...

# Anthropic — used for anti-cheat anomaly detection
ANTHROPIC_API_KEY=sk-ant-...

# H3
H3_RESOLUTION=8
