PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/movenrun

# Redis
REDIS_URL=redis://localhost:6379

# Oracle signing key (private key for the trusted oracle)
ORACLE_PRIVATE_KEY=0x...

# Base chain
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Contract addresses (fill after deployment)
MOVE_TOKEN_ADDRESS=0x...
ZONE_NFT_ADDRESS=0x...
GEAR_NFT_ADDRESS=0x...
ZONE_CHALLENGE_ADDRESS=0x...
SEASON_CONTROLLER_ADDRESS=0x...

# Anthropic (for anomaly detection assistance)
ANTHROPIC_API_KEY=sk-ant-...

# H3
H3_RESOLUTION=8

# Wallet-signature auth (see backend/src/middleware/auth.ts) — how long a
# signed request stays valid after its issuedAt timestamp.
AUTH_MAX_AGE_SECONDS=300

# CORS allowlist (see backend/src/middleware/security.ts), comma-separated.
# In development/test, an unset value falls back to common local dev origins.
# In PRODUCTION this MUST be set to an explicit allowlist — an unset value,
# or a value containing a literal "*", makes the backend fail to start
# (fail closed). Never use "*" in production.
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000

# Rate limiting (see backend/src/middleware/rateLimit.ts). RATE_LIMIT_MAX is
# the app-wide limit per RATE_LIMIT_WINDOW_MS; RATE_LIMIT_WRITE_MAX is the
# stricter per-write-endpoint limit over the same window.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_WRITE_MAX=20
