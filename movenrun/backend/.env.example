PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/movenrun

# Redis
REDIS_URL=redis://localhost:6379

# Oracle signing key (private key for the trusted oracle)
ORACLE_PRIVATE_KEY=0x...

# Base chain
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Contract addresses (fill after deployment)
MOVE_TOKEN_ADDRESS=0x...
ZONE_NFT_ADDRESS=0x...
GEAR_NFT_ADDRESS=0x...
ZONE_CHALLENGE_ADDRESS=0x...
SEASON_CONTROLLER_ADDRESS=0x...

# Anthropic (for anti-cheat route analysis — uses claude-haiku-4-5-20251001 with prompt caching)
ANTHROPIC_API_KEY=sk-ant-...

# Device attestation (set to true in development to bypass Apple/Android checks)
SKIP_DEVICE_ATTESTATION=false

# H3
H3_RESOLUTION=8
