{
  "name": "@movenrun/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/blockchain/*.test.ts src/services/*.test.ts src/repositories/*.test.ts src/middleware/*.test.ts src/identity/**/*.test.ts",
    "worker:gps": "tsx src/workers/gps.worker.ts",
    "worker:keeper": "tsx src/workers/keeper.worker.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@movenrun/shared": "workspace:*",
    "bullmq": "^5.7.8",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.31.0",
    "ethers": "^6.12.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "h3-js": "^4.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5"
  }
}
