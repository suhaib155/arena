{
  "expo": {
    "name": "MovenRun",
    "slug": "movenrun",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "movenrun",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B12",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.movenrun.app"
    },
    "android": {
      "package": "io.movenrun.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B12"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": "FILL_ME_IN"
      }
    }
  }
}
