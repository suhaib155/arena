# ── Deployer ─────────────────────────────────────────────────────────────────
# Private key of the wallet that will deploy (must hold Base Sepolia ETH)
# Faucet: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
DEPLOYER_PRIVATE_KEY=0x...

# ── Operator addresses ────────────────────────────────────────────────────────
# EOA that signs GPS routes off-chain (backend oracle service)
ORACLE_ADDRESS=0x...

# Admin address that receives DEFAULT_ADMIN_ROLE on all contracts
ADMIN_ADDRESS=0x...

# Treasury address for SeasonController greatBurn
TREASURY_ADDRESS=0x...

# ── RPC URLs ──────────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# ── Basescan API key (for contract verification) ──────────────────────────────
# Get one at: https://basescan.org/apis
BASESCAN_API_KEY=
