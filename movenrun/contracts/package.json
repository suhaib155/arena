{
  "name": "@movenrun/contracts",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy/local.ts --network localhost",
