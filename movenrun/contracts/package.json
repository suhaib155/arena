    "deploy:mainnet": "hardhat run scripts/deploy/baseSepolia.ts --network baseMainnet",
    "verify:sepolia": "hardhat run scripts/verify/verifyAll.ts --network baseSepolia",
    "verify": "hardhat run scripts/verify/verifyAll.ts --network baseSepolia",
    "node": "hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@chainlink/contracts": "^1.2.0",
    "hardhat": "^2.22.3",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "ethers": "^6.12.1",
    "dotenv": "^16.4.5"
  }
}
